{
	"$schema": "../ng-openapi-gen-schema.json",
	"input": "validation-schemas.json",
	"output": "out/validation-schemas",
	"ignoreUnusedModels": false,
	"apiService": false,
	"validation": {
		"enabled": true,
		"defaultImportPath": "@angular/forms/signals",
		"mapping": {
			"format:date": {
				"validator": "date",
				"template": "date({{path}})",
				"importPath": "@common"
			},
			"format:date-time": {
				"validator": "date",
				"template": "date({{path}})",
				"importPath": "@common"
			}
		}
	}
}
