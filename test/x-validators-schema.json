{
	"openapi": "3.0.3",
	"info": {
		"title": "X-Validators Schema Mode Test API",
		"version": "1.0.0"
	},
	"paths": {
		"/agences": {
			"post": {
				"operationId": "createAgence",
				"tags": ["Agences"],
				"requestBody": {
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/AgenceInputDTO"
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "Success"
					}
				}
			}
		}
	},
	"components": {
		"schemas": {
			"AgenceInputDTO": {
				"type": "object",
				"required": ["libelle", "numerosTelephones"],
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"libelle": {
						"minLength": 1,
						"maxLength": 30,
						"type": "string",
						"x-validators": [{ "name": "required" }, { "name": "maxLength", "value": 30 }]
					},
					"libelleInterne": {
						"maxLength": 50,
						"type": "string",
						"nullable": true,
						"x-validators": [{ "name": "maxLength", "value": 50 }]
					},
					"numerosTelephones": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/NumeroTelephoneInputDTO"
						}
					}
				},
				"additionalProperties": false
			},
			"NumeroTelephoneInputDTO": {
				"required": ["telephone"],
				"type": "object",
				"properties": {
					"id": {
						"type": "integer",
						"format": "int32"
					},
					"codeNatureTelephone": {
						"$ref": "#/components/schemas/CodeNatureTelephone"
					},
					"gpcQueueGuid": {
						"type": "string",
						"format": "uuid",
						"nullable": true
					},
					"telephone": {
						"minLength": 1,
						"pattern": "^(\\+33|0033|0)(1|2|3|4|5|6|7)[0-9]{8}$",
						"type": "string",
						"format": "phone-fr",
						"x-validators": [{ "name": "required" }, { "name": "phoneFr", "message": "Format de téléphone invalide" }]
					}
				},
				"additionalProperties": false
			},
			"CodeNatureTelephone": {
				"type": "string",
				"enum": ["FIXE", "MOBILE", "FAX"]
			},
			"AdresseInputDTO": {
				"type": "object",
				"properties": {
					"rue": {
						"maxLength": 100,
						"type": "string",
						"x-validators": [{ "name": "maxLength", "value": 100 }]
					},
					"codePostal": {
						"type": "string",
						"x-validators": [{ "name": "zipCodeFr" }]
					},
					"ville": {
						"maxLength": 50,
						"type": "string",
						"x-validators": [{ "name": "required" }, { "name": "maxLength", "value": 50 }]
					}
				}
			},
			"ContactInputDTO": {
				"type": "object",
				"required": ["email"],
				"properties": {
					"email": {
						"type": "string",
						"format": "email",
						"x-validators": [{ "name": "required" }, { "name": "email" }]
					},
					"mobile": {
						"type": "string",
						"x-validators": [{ "name": "mobileFr" }]
					},
					"iban": {
						"type": "string",
						"x-validators": [{ "name": "iban" }]
					},
					"bic": {
						"type": "string",
						"x-validators": [{ "name": "bic" }]
					},
					"adresse": {
						"$ref": "#/components/schemas/AdresseInputDTO"
					}
				}
			}
		}
	}
}
